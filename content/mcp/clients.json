      "install": {
        "kind": "file",
        "path": "{scopePath}",
        "language": "yaml",
        "snippet": "name: vaner\nversion: 0.0.1\nschema: v1\ncommand: {launcherCommand}\nargs:\n{launcherArgsYamlWithDotPath}\n",
